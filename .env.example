APP_ENV=development
APP_URL=http://localhost:8080
PORT=8080

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=money_manager_db
DB_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

KIE_AI_API_KEY=your_kie_ai_api_key
KIE_AI_MODEL=gpt-5-4
KIE_AI_BASE_URL=https://api.kie.ai
KIE_AI_REASONING_EFFORT=low

FONNTE_TOKEN=your_fonnte_token
FONNTE_WEBHOOK_TOKEN=your_fonnte_webhook_token
FONNTE_DEVICE_ID=your_device_id

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=your_admin_password
BCRYPT_COST=12

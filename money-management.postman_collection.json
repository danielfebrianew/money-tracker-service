            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device\": \"628000000000\",\n  \"sender\": \"628123456789\",\n  \"message\": \"makan siang 25rb\",\n  \"text\": \"\",\n  \"member\": \"\",\n  \"name\": \"Daniel\",\n  \"location\": \"\",\n  \"url\": \"\",\n  \"filename\": \"\",\n  \"extension\": \"\",\n  \"pollname\": \"\",\n  \"choices\": \"\",\n  \"inboxid\": \"80367170\",\n  \"timestamp\": \"1711962000\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/wa/webhook", "host": ["{{base_url}}"], "path": ["api", "wa", "webhook"] },
            "description": "Always returns 200 immediately. Processing happens async. Check logs or your WhatsApp for the reply."
          }
